    // ====================
    // INDIVIDUAL MAINTENANCE REPORT
    // ====================

    exportMaintenanceLogReportPDF: (vehicleId: string) => {
        const vehicle = VEHICLE_DETAILS.find(v => v.vehicleId === vehicleId);
        const maintenanceLogs = MAINTENANCE_RECORDS.filter(m => m.vehicleId === vehicleId);

        if (!vehicle) {
            alert('Vehicle not found!');
            return;
        }

        const doc = new jsPDF();
        const fileName = `Maintenance_Log_${vehicle.licensePlate.replace(/-/g, '_')}_Report.pdf`;

        doc.setFontSize(20);
        doc.setFont('helvetica', 'bold');
        doc.text(`Maintenance Records: ${vehicle.licensePlate}`, 14, 20);

        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        doc.text(`Vehicle: ${vehicle.make} ${vehicle.model}`, 14, 30);
        doc.text(`Total Records: ${maintenanceLogs.length}`, 14, 36);

        const totalCost = maintenanceLogs
            .filter(m => m.status === 'Completed')
            .reduce((sum, m) => sum + m.cost, 0);

        autoTable(doc, {
            startY: 44,
            head: [['Date', 'Type', 'Cost', 'Status', 'Mechanic']],
            body: maintenanceLogs.map(m => [
                m.serviceDate,
                m.serviceType,
                `$${m.cost}`,
                m.status,
                m.mechanic
            ]),
            theme: 'grid',
            headStyles: { fillColor: [245, 158, 11] }
        });

        const finalY = (doc as any).lastAutoTable.finalY + 10;
        doc.setFontSize(12);
        doc.setFont('helvetica', 'bold');
        doc.text(`Total Maintenance Cost: $${totalCost}`, 14, finalY);

        doc.save(fileName);
    },

