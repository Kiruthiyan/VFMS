import jsPDF from 'jspdf';
import autoTable from 'jspdf-autotable';
import * as XLSX from 'xlsx';
import {
    VEHICLE_DETAILS,
    MAINTENANCE_RECORDS,
    FUEL_LOGS,
    VEHICLE_UTILIZATION,
    DRIVER_PERFORMANCE,
    RENTAL_RECORDS,
    getOverallSummary
} from './enhancedMockData';

// Mock data imports
