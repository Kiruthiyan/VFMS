    // ====================
    // INDIVIDUAL FUEL LOG REPORT
    // ====================

    exportFuelLogReportPDF: (vehicleId: string) => {
        const vehicle = VEHICLE_DETAILS.find(v => v.vehicleId === vehicleId);
        const fuelLogs = FUEL_LOGS.filter(f => f.vehicleId === vehicleId);

        if (!vehicle) {
            alert('Vehicle not found!');
            return;
        }

        const doc = new jsPDF();
        const fileName = `Fuel_Log_${vehicle.licensePlate.replace(/-/g, '_')}_Report.pdf`;

        doc.setFontSize(20);
        doc.setFont('helvetica', 'bold');
        doc.text(`Fuel Logs: ${vehicle.licensePlate}`, 14, 20);

        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        doc.text(`Vehicle: ${vehicle.make} ${vehicle.model}`, 14, 30);
        doc.text(`Total Logs: ${fuelLogs.length}`, 14, 36);

        const totalCost = fuelLogs.reduce((sum, f) => sum + f.totalCost, 0);
        const totalQuantity = fuelLogs.reduce((sum, f) => sum + f.fuelQuantity, 0);

        autoTable(doc, {
            startY: 44,
            head: [['Date', 'Quantity (L)', 'Price/L', 'Total Cost', 'Station']],
            body: fuelLogs.map(f => [
                f.date,
                f.fuelQuantity.toString(),
                `$${f.pricePerLiter}`,
                `$${f.totalCost}`,
                f.fuelStation
            ]),
            foot: [['TOTAL', totalQuantity.toString() + ' L', '', `$${totalCost}`, '']],
            theme: 'grid',
            headStyles: { fillColor: [34, 197, 94] }
        });

        doc.save(fileName);
    },

    exportFuelLogReportExcel: (vehicleId: string) => {
