    { month: "Jan", cost: 500 },
    { month: "Feb", cost: 350 },
    { month: "Mar", cost: 800 },
    { month: "Apr", cost: 200 },
    { month: "May", cost: 450 },
    { month: "Jun", cost: 650 }
];

const MOCK_FUEL_DATA = [
    { month: "Jan", cost: 1200 },
    { month: "Feb", cost: 1150 },
    { month: "Mar", cost: 1300 },
    { month: "Apr", cost: 900 },
    { month: "May", cost: 1100 },
    { month: "Jun", cost: 950 }
];

const MOCK_VEHICLE_DATA = [
    { licensePlate: "KA-01-AB-1234", distance: 5200, trips: 45, fuel: 600 },
    { licensePlate: "KA-05-XY-9876", distance: 3800, trips: 30, fuel: 450 },
    { licensePlate: "TN-09-CD-4567", distance: 6100, trips: 52, fuel: 720 },
    { licensePlate: "KL-07-EF-3210", distance: 2400, trips: 15, fuel: 280 }
];

const MOCK_DRIVER_DATA = [
    { name: "Ramesh Kumar", trips: 45, distance: 5200, rating: 4.8 },
    { name: "Suresh Singh", trips: 30, distance: 3800, rating: 3.5 },
    { name: "Abdul Rahim", trips: 52, distance: 6100, rating: 4.9 },
    { name: "John Doe", trips: 15, distance: 2400, rating: 4.2 }
