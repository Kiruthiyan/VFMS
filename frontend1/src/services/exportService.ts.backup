    // Maintenance Cost Export
    exportMaintenancePDF: (startDate?: string, endDate?: string) => {
        const doc = new jsPDF();

        // Filter data if dates provided
        let filteredData = MAINTENANCE_RECORDS;
        let periodText = 'All Time';
        let filenameSuffix = '';

        if (startDate && endDate) {
            const start = new Date(startDate);
            const end = new Date(endDate);
            filteredData = MAINTENANCE_RECORDS.filter(record => {
                const recordDate = new Date(record.serviceDate);
                return recordDate >= start && recordDate <= end;
            });
            periodText = `${start.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`;
            filenameSuffix = `_${start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '_')}`;
        }

        doc.setFontSize(18);
        doc.text('Maintenance Cost Report', 14, 20);

        doc.setFontSize(11);
        doc.text('Generated on: ' + new Date().toLocaleDateString(), 14, 30);
        doc.text('Period: ' + periodText, 14, 36);

        const totalCost = filteredData.reduce((sum, item) => sum + item.cost, 0);
        doc.text(`Total Maintenance Cost: $${totalCost.toFixed(2)}`, 14, 46);

        autoTable(doc, {
            startY: 54,
            head: [['Date', 'Vehicle', 'Type', 'Cost ($)']],
            body: filteredData.map(item => [
                item.serviceDate,
                item.vehicleId,
                item.serviceType,
                item.cost.toFixed(2)
            ])
        });

        doc.save(`maintenance_report${filenameSuffix}.pdf`);
    },

    exportMaintenanceExcel: (startDate?: string, endDate?: string) => {
        let filteredData = MAINTENANCE_RECORDS;
        let filenameSuffix = '';

        if (startDate && endDate) {
            const start = new Date(startDate);
            const end = new Date(endDate);
            filteredData = MAINTENANCE_RECORDS.filter(record => {
                const recordDate = new Date(record.serviceDate);
                return recordDate >= start && recordDate <= end;
            });
            filenameSuffix = `_${start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '_')}`;
        }

        const data = filteredData.map(item => ({
            Date: item.serviceDate,
            Vehicle: item.vehicleId,
            'Service Type': item.serviceType,
            const totalCost = filteredData.reduce((sum, item) => sum + item.cost, 0);
            data.push({ Date: 'TOTAL', Vehicle: '', 'Service Type': '', Description: '', 'Cost ($)': totalCost, Status: 'Completed' });

            const ws = XLSX.utils.json_to_sheet(data);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Maintenance Report');
            XLSX.writeFile(wb, `maintenance_report${filenameSuffix}.xlsx`);
        },

            // Fuel Analysis Export
            exportFuelPDF: (startDate?: string, endDate?: string) => {
                const doc = new jsPDF();

                let filteredData = FUEL_LOGS;
                let periodText = 'All Time';
                let filenameSuffix = '';

                if (startDate && endDate) {
                    const start = new Date(startDate);
                    const end = new Date(endDate);
                    filteredData = FUEL_LOGS.filter(log => {
                        const logDate = new Date(log.date);
                        return logDate >= start && logDate <= end;
                    });
                    periodText = `${start.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`;
                    filenameSuffix = `_${start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '_')}`;
                }

                doc.setFontSize(18);
                doc.text('Fuel Analysis Report', 14, 20);

                doc.setFontSize(11);
                doc.text('Generated on: ' + new Date().toLocaleDateString(), 14, 30);
                doc.text('Period: ' + periodText, 14, 36);

                const totalCost = filteredData.reduce((sum, item) => sum + item.totalCost, 0);
                const totalQuantity = filteredData.reduce((sum, item) => sum + item.fuelQuantity, 0);
                doc.text(`Total Fuel Cost: $${totalCost.toFixed(2)}`, 14, 46);
                doc.text(`Total Quantity: ${totalQuantity.toFixed(2)} L`, 14, 52);

                autoTable(doc, {
                    startY: 60,
                    head: [['Date', 'Vehicle', 'Quantity (L)', 'Cost ($)']],
                    body: filteredData.map(item => [
                        item.date,
                        item.vehicleId,
                        item.fuelQuantity.toFixed(2),
                        item.totalCost.toFixed(2)
                    ])
                });

                doc.save(`fuel_analysis_report${filenameSuffix}.pdf`);
            },

            exportFuelExcel: (startDate?: string, endDate?: string) => {
                let filteredData = FUEL_LOGS;
                let filenameSuffix = '';

                if (startDate && endDate) {
                    const start = new Date(startDate);
                    const end = new Date(endDate);
                    filteredData = FUEL_LOGS.filter(log => {
                        const logDate = new Date(log.date);
                        return logDate >= start && logDate <= end;
                    });
                    filenameSuffix = `_${start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '_')}`;
                }

                const data = filteredData.map(item => ({
                    Date: item.date,
                    Vehicle: item.vehicleId,
                    'Quantity (L)': item.fuelQuantity,

                    // Vehicle Utilization Export
                    exportUtilizationPDF: (startDate?: string, endDate?: string) => {
                        const doc = new jsPDF();

                        let periodText = 'All Time';
                        let filenameSuffix = '';

                        if (startDate && endDate) {
                            const start = new Date(startDate);
                            periodText = `${start.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`;
                            filenameSuffix = `_${start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '_')}`;
                        }

                        doc.setFontSize(18);
                        doc.text('Vehicle Utilization Report', 14, 20);

                        doc.setFontSize(11);
                        doc.text('Generated on: ' + new Date().toLocaleDateString(), 14, 30);

                        exportUtilizationExcel: (startDate?: string, endDate?: string) => {
                            let filenameSuffix = '';

                            if (startDate && endDate) {
                                const start = new Date(startDate);
                                filenameSuffix = `_${start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '_')}`;
                            }

                            const data = VEHICLE_UTILIZATION.map(item => ({
                                'License Plate': item.licensePlate,
                                'Distance (km)': item.totalDistance,
                                'Trips': item.totalTrips,
                                'Hours': item.totalHours,
                                'Utilization Rate (%)': item.utilizationRate,
                                'Avg Trip Distance (km)': item.avgTripDistance
                            }));

                            const ws = XLSX.utils.json_to_sheet(data);
                            const wb = XLSX.utils.book_new();
                            XLSX.utils.book_append_sheet(wb, ws, 'Vehicle Utilization');
                            XLSX.writeFile(wb, `vehicle_utilization_report${filenameSuffix}.xlsx`);
                        },

                            // Driver Performance Export
                            exportPerformancePDF: (startDate?: string, endDate?: string) => {
                                const doc = new jsPDF();

                                let periodText = 'All Time';
                                let filenameSuffix = '';

                                if (startDate && endDate) {
                                    const start = new Date(startDate);
                                    periodText = `${start.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`;
                                    filenameSuffix = `_${start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '_')}`;
                                }

                                doc.setFontSize(18);
                                doc.text('Driver Performance Report', 14, 20);

                                doc.setFontSize(11);
                                doc.text('Generated on: ' + new Date().toLocaleDateString(), 14, 30);
                                doc.text('Period: ' + periodText, 14, 36);

                                autoTable(doc, {
                                    startY: 44,
                                    head: [['Driver Name', 'Total Trips', 'Distance (km)', 'Rating']],
                                    body: DRIVER_PERFORMANCE.map(item => [
                                        item.driverName,
                                        item.totalTrips,
                                        item.totalDistance,
                                        item.feedbackRating.toFixed(1)
                                    ])
                                });

                                doc.save(`driver_performance_report${filenameSuffix}.pdf`);
                            },

                                exportPerformanceExcel: (startDate?: string, endDate?: string) => {
                                    let filenameSuffix = '';

                                    if (startDate && endDate) {
                                        const start = new Date(startDate);
                                        filenameSuffix = `_${start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).replace(' ', '_')}`;
                                    }

                                    const data = DRIVER_PERFORMANCE.map(item => ({
                                        'Driver Name': item.driverName,
                                        'License Number': item.licenseNumber,
                                        'Total Trips': item.totalTrips,
                                        'Distance (km)': item.totalDistance,
                                        'Rating': item.feedbackRating,
                                        'Safety Score': item.safetyScore,
                                        'Violations': item.violations
                                    }));

                                    const ws = XLSX.utils.json_to_sheet(data);
                                    const wb = XLSX.utils.book_new();
                                    XLSX.utils.book_append_sheet(wb, ws, 'Driver Performance');
                                    XLSX.writeFile(wb, `driver_performance_report${filenameSuffix}.xlsx`);
                                }
                    };
