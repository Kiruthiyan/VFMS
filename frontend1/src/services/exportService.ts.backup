export const exportService = {
    // ====================
    // OVERALL SUMMARY EXPORTS
    // ====================

    exportOverallSummaryPDF: () => {
        const doc = new jsPDF();
        const summary = getOverallSummary();
        const fileName = `VFMS_Overall_Report_${summary.reportDate.replace(' ', '_')}.pdf`;

        // Title
        doc.setFontSize(20);
        doc.setFont('helvetica', 'bold');
        doc.text('VFMS - Overall Fleet Report', 14, 20);

        // Report Info
        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        doc.text(`Report Period: ${summary.reportDate}`, 14, 30);
        doc.text(`Generated: ${new Date().toLocaleDateString()}`, 14, 36);

        // Fleet Summary
        doc.setFontSize(14);
        doc.setFont('helvetica', 'bold');
        doc.text('Fleet Summary', 14, 50);

        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        autoTable(doc, {
            startY: 56,
            head: [['Metric', 'Value']],
            body: [
                ['Total Vehicles', summary.totalVehicles.toString()],
                ['Total Drivers', summary.totalDrivers.toString()],
                ['Total Trips', summary.totalTrips.toLocaleString()],
                ['Total Distance (km)', summary.totalDistance.toLocaleString()],
                ['Average Utilization', `${summary.averageUtilization}%`]
            ],
            theme: 'grid',
            headStyles: { fillColor: [51, 122, 183] }
        });

        const finalY1 = (doc as any).lastAutoTable.finalY + 10;

        // Financial Summary
        doc.setFontSize(14);
        doc.setFont('helvetica', 'bold');
        doc.text('Financial Summary', 14, finalY1);

        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        autoTable(doc, {
            startY: finalY1 + 6,
            head: [['Category', 'Amount ($)']],
            body: [
                ['Total Maintenance Cost', summary.totalMaintenanceCost.toFixed(2)],
                ['Total Fuel Cost', summary.totalFuelCost.toFixed(2)],
                ['Total Operating Cost', (summary.totalMaintenanceCost + summary.totalFuelCost).toFixed(2)]
            ],
            theme: 'grid',
            headStyles: { fillColor: [92, 184, 92] }
        });

        const finalY2 = (doc as any).lastAutoTable.finalY + 10;

        // Driver Performance
        doc.setFontSize(14);
        doc.setFont('helvetica', 'bold');
        doc.text('Driver Performance', 14, finalY2);

        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        autoTable(doc, {
            startY: finalY2 + 6,
            head: [['Metric', 'Value']],
            body: [
                ['Average Driver Rating', `${summary.averageDriverRating}/5.0`],
                ['Total Violations', summary.totalViolations.toString()]
            ],
            theme: 'grid',
            headStyles: { fillColor: [240, 173, 78] }
        });

        doc.save(fileName);
    },

    exportOverallSummaryExcel: () => {
        const summary = getOverallSummary();
        const fileName = `VFMS_Overall_Report_${summary.reportDate.replace(' ', '_')}.xlsx`;

        // Fleet Summary Sheet
        const fleetData = [
            { Metric: 'Total Vehicles', Value: summary.totalVehicles },
            { Metric: 'Total Drivers', Value: summary.totalDrivers },
            { Metric: 'Total Trips', Value: summary.totalTrips },
            { Metric: 'Total Distance (km)', Value: summary.totalDistance },
            { Metric: 'Average Utilization (%)', Value: summary.averageUtilization }
        ];

        // Financial Summary Sheet
        const financialData = [
            { Category: 'Total Maintenance Cost', 'Amount ($)': summary.totalMaintenanceCost },
            { Category: 'Total Fuel Cost', 'Amount ($)': summary.totalFuelCost },
            { Category: 'Total Operating Cost', 'Amount ($)': summary.totalMaintenanceCost + summary.totalFuelCost }
        ];

        // Driver Performance Sheet
        const driverSummaryData = [
            { Metric: 'Average Driver Rating', Value: summary.averageDriverRating },
            { Metric: 'Total Violations', Value: summary.totalViolations }
        ];

        const wb = XLSX.utils.book_new();

        const wsFleet = XLSX.utils.json_to_sheet(fleetData);
        const wsFinancial = XLSX.utils.json_to_sheet(financialData);
        const wsDriver = XLSX.utils.json_to_sheet(driverSummaryData);

        XLSX.utils.book_append_sheet(wb, wsFleet, 'Fleet Summary');
        XLSX.utils.book_append_sheet(wb, wsFinancial, 'Financial Summary');
        XLSX.utils.book_append_sheet(wb, wsDriver, 'Driver Performance');

        XLSX.writeFile(wb, fileName);
    },

    // ====================
    // INDIVIDUAL VEHICLE REPORT
    // ====================

    exportVehicleReportPDF: (vehicleId: string) => {
        const vehicle = VEHICLE_DETAILS.find(v => v.vehicleId === vehicleId);
        if (!vehicle) {
            alert('Vehicle not found!');
            return;
        }

        const doc = new jsPDF();
        const fileName = `Vehicle_${vehicle.licensePlate.replace(/-/g, '_')}_Report.pdf`;

        // Title
        doc.setFontSize(20);
        doc.setFont('helvetica', 'bold');
        doc.text(`Vehicle Report: ${vehicle.licensePlate}`, 14, 20);

        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        doc.text(`Generated: ${new Date().toLocaleDateString()}`, 14, 30);

        // Vehicle Details
        doc.setFontSize(14);
        doc.setFont('helvetica', 'bold');
        doc.text('Vehicle Information', 14, 44);

        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        autoTable(doc, {
            startY: 50,
            head: [['Field', 'Value']],
            body: [
                ['Vehicle ID', vehicle.vehicleId],
                ['License Plate', vehicle.licensePlate],
                ['Make & Model', `${vehicle.make} ${vehicle.model}`],
                ['Year', vehicle.year.toString()],
                ['Last Service Date', vehicle.lastServiceDate]
            ],
            theme: 'grid',
            headStyles: { fillColor: [51, 122, 183] }
        });

        const finalY1 = (doc as any).lastAutoTable.finalY + 10;

        // Performance Metrics
        doc.setFontSize(14);
        doc.setFont('helvetica', 'bold');
        doc.text('Performance Metrics', 14, finalY1);

        doc.setFontSize(11);
        doc.setFont('helvetica', 'normal');
        autoTable(doc, {
            startY: finalY1 + 6,
            head: [['Metric', 'Value']],
            body: [
                ['Total Trips', vehicle.totalTrips.toString()],
                ['Total Distance (km)', vehicle.totalDistance.toLocaleString()],
                ['Utilization Status', vehicle.utilizationStatus],
                ['Fuel Cost ($)', vehicle.fuelCost.toFixed(2)],
                ['Maintenance Cost ($)', vehicle.maintenanceCost.toFixed(2)],
                ['Total Operating Cost ($)', (vehicle.fuelCost + vehicle.maintenanceCost).toFixed(2)]
            ],
            theme: 'grid',
            headStyles: { fillColor: [92, 184, 92] }
        });

        doc.save(fileName);
    },

    exportVehicleReportExcel: (vehicleId: string) => {
        const vehicle = VEHICLE_DETAILS.find(v => v.vehicleId === vehicleId);
        if (!vehicle) {
            alert('Vehicle not found!');
            return;
        }

        const fileName = `Vehicle_${vehicle.licensePlate.replace(/-/g, '_')}_Report.xlsx`;

        const data = [
            { Field: 'Vehicle ID', Value: vehicle.vehicleId },
            { Field: 'License Plate', Value: vehicle.licensePlate },
            { Field: 'Make & Model', Value: `${vehicle.make} ${vehicle.model}` },
            { Field: 'Year', Value: vehicle.year },
            { Field: 'Total Trips', Value: vehicle.totalTrips },
            { Field: 'Total Distance (km)', Value: vehicle.totalDistance },
            { Field: 'Fuel Cost ($)', Value: vehicle.fuelCost },
            { Field: 'Maintenance Cost ($)', Value: vehicle.maintenanceCost },
            { Field: 'Total Operating Cost ($)', Value: vehicle.fuelCost + vehicle.maintenanceCost },
            { Field: 'Utilization Status', Value: vehicle.utilizationStatus },
            { Field: 'Last Service Date', Value: vehicle.lastServiceDate }
        ];

        const ws = XLSX.utils.json_to_sheet(data);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, 'Vehicle Report');

        XLSX.writeFile(wb, fileName);
    },

