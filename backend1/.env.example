# Copy this file to backend1/.env and fill in your local values.
# Never commit backend1/.env to version control.

# ===============================
# DATABASE
# ===============================
DB_URL=jdbc:postgresql://localhost:5432/vfms_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_DRIVER=org.postgresql.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ===============================
# JWT
# ===============================
JWT_SECRET=replace-with-a-strong-32-char-plus-secret

# ===============================
# ADMIN SEED (first-run bootstrap)
# Password is encoded with BCrypt at startup — store plain text here only in local .env
# ===============================
ADMIN_SEED_ENABLED=true
ADMIN_SEED_CLEANUP_DEMO_USERS=true
ADMIN_SEED_EMAIL=kiruthiyan8@gmail.com
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FULL_NAME=Kiruthiyan Admin
ADMIN_SEED_PHONE=0770000000
ADMIN_SEED_NIC=200012345678

# ===============================
# FRONTEND / CORS
# ===============================
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ===============================
# EMAIL (optional for local dev)
# ===============================
MAIL_USERNAME=
MAIL_PASSWORD=

# ===============================
# SUPABASE STORAGE (optional — required only for fuel receipt uploads)
# ===============================
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_BUCKET=fuel-receipts
SUPABASE_SERVICE_KEY=
