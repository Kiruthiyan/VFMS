# ===============================
# REPOSITORY-WIDE IGNORE RULES
# ===============================

# OS files
.DS_Store
Thumbs.db

# Logs and temp files
*.log
*.tmp
*.swp
*.swo
*.orig

# Environment files
.env
.env.*
!.env.example

# Editors and local tooling
.idea/
.vscode/
.claude/

# Node / Next.js
node_modules/
.next/
out/
dist/
coverage/
*.tsbuildinfo

# Java / Maven
target/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar
backend/.m2/

# Database and storage artifacts
*.db
*.mv.db
*.lock.db
backend/data/
backend/uploads/

# IDE-specific Java files
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/
build/

# Deployment
.vercel/

