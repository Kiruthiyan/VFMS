# ===============================
# VFMS — repository-wide ignore rules
# ===============================

# OS
.DS_Store
Thumbs.db

# Logs and temp
*.log
*.tmp
*.swp
*.swo
*.orig
test_output.txt
test_results_*.txt

# Local env / secrets (never commit)
.env
.env.*
!.env.example
*.local.env

# Disposable local archive (removed after review)
_bin/
cleanup-bin/

# Editors / AI tooling
.idea/
.vscode/
.claude/
*.iml
*.ipr
*.iws

# Node / Next.js
node_modules/
.next/
out/
dist/
build/
coverage/
.vercel/
*.tsbuildinfo

# Java / Maven
target/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar
backend/.m2/

# Local DB / uploads
*.db
*.mv.db
*.lock.db
uploads/

# Eclipse / STS / NetBeans (legacy IDE)
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# Security keys
*.pem

# Backend local overrides (use .env + application-dev.properties)
backend1/src/main/resources/application.properties
