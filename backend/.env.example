# Example environment variables for VFMS backend
# Copy to backend/.env and fill with real values (DO NOT commit .env)

# Database (Postgres for production)
DB_URL=jdbc:postgresql://your-db-host:5432/your-db-name
DB_USER=your_db_user
DB_PASSWORD=your_db_password_here

# JWT
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email_address_here
MAIL_PASSWORD=your_app_password_here

# CORS and frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Supabase storage
SUPABASE_STORAGE_URL=your_supabase_storage_url
SUPABASE_STORAGE_BUCKET=fuel-receipts
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# External APIs
VEHICLE_API_BASE_URL=http://localhost:8080/api/vehicles

# App-specific
VFMS_TEMP_PASSWORD_LENGTH=10
VFMS_TEMP_PASSWORD_CHARS=ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@#$%

# Admin seed (only use for first-run bootstrap, revoke after use)
ADMIN_SEED_ENABLED=false
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FULL_NAME=
ADMIN_SEED_PHONE=
ADMIN_SEED_NIC=