# Copy this file to backend/.env and fill in your local values.
# Never commit backend/.env to version control.

# ===============================
# DATABASE
# ===============================
# Supabase PostgreSQL only (Project Settings → Database → Connection string → JDBC)
DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
DB_DRIVER=org.postgresql.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ===============================
# JWT
# ===============================
JWT_SECRET=replace-with-a-strong-32-char-plus-secret

# ===============================
# ADMIN SEED (first-run bootstrap)
# Password is encoded with BCrypt at startup — store plain text here only in local .env
# ===============================
ADMIN_SEED_ENABLED=true
ADMIN_SEED_CLEANUP_DEMO_USERS=false
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-local-only
ADMIN_SEED_FULL_NAME=System Administrator
ADMIN_SEED_PHONE=0000000000
ADMIN_SEED_NIC=000000000V

# ===============================
# FRONTEND / CORS
# ===============================
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ===============================
# EMAIL (optional for local dev)
# ===============================
MAIL_USERNAME=
MAIL_PASSWORD=

# ===============================
# SUPABASE STORAGE (optional — required only for fuel receipt uploads)
# ===============================
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_BUCKET=fuel-receipts
SUPABASE_SERVICE_KEY=
