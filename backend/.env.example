# Example environment variables for VFMS backend
# Copy to backend/.env and fill with real values (DO NOT commit .env)

# Database (Postgres for production)
DB_URL=jdbc:postgresql://<db-host>:5432/<db-name>
DB_USER=postgres
DB_PASSWORD=changeme

# JWT
JWT_SECRET=replace-with-a-strong-32-char-plus-secret

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password

# CORS and frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Supabase storage
SUPABASE_STORAGE_URL=
SUPABASE_STORAGE_BUCKET=fuel-receipts
SUPABASE_SERVICE_KEY=

# External APIs
VEHICLE_API_BASE_URL=http://localhost:8080/api/vehicles

# App-specific
VFMS_TEMP_PASSWORD_LENGTH=10
VFMS_TEMP_PASSWORD_CHARS=ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@#$%

# Admin seed (only use for first-run bootstrap, revoke after use)
ADMIN_SEED_ENABLED=false
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FULL_NAME=
ADMIN_SEED_PHONE=
ADMIN_SEED_NIC=